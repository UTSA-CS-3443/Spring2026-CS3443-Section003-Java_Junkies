<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.budgetwise.controller.LoginController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <Label text="Welcome to BudgetWise">
        <font>
            <Font name="System Bold" size="24.0" />
        </font>
    </Label>

    <Label text="Please log in to continue" textFill="#666666" />

    <TextField fx:id="usernameField" maxWidth="250.0" promptText="Username" />

    <PasswordField fx:id="passwordField" maxWidth="250.0" promptText="Password" />

    <Button mnemonicParsing="false" onAction="#handleLoginAction" prefWidth="250.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold;" text="Log In" />

    <Label fx:id="errorMessage" textFill="RED" />
</VBox>