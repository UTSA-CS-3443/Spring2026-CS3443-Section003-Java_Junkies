<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.budgetwise.controller.TransactionsController"
            style="-fx-background-color: #F7F8FC;">

    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <Label text="Transactions"
                   style="-fx-font-size: 34px; -fx-font-weight: bold;"/>

            <TableView fx:id="transactionsTable" prefHeight="500">

                <columns>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="120"/>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="120"/>
                    <TableColumn fx:id="categoryColumn" text="Category" prefWidth="150"/>
                    <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="250"/>
                    <TableColumn fx:id="amountColumn" text="Amount" prefWidth="120"/>
                </columns>

            </TableView>

        </VBox>
    </center>
</BorderPane>